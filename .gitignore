# --- Tracked on purpose: *.csv, reports/, *.ipynb, data/, src/, notebooks/, etc. ---

# Virtual environments
venv/
.venv/
env/

# Python bytecode / packaging
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
MANIFEST

# Build / distribution (Python packages)
dist/
build/
pip-wheel-metadata/

# Testing / coverage / typing / linters
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# Environment & secrets (never commit)
.env
.env.*
*.pem
secrets/
credentials.json
*.key

# OS
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~

# Editors / local IDE (remove a line if your team commits shared configs)
.idea/
.cursor/
*.code-workspace

# Jupyter (notebook files stay tracked)
.ipynb_checkpoints/

# Logs (project logs; keep tracked CSVs / figures if you want them versioned)
*.log
logs/

# Large ML artifacts
*.pkl
models/autogluon_delivery_time/
models/**/autogluon*/

# Regenerated deployment bundles (rebuild: python deployment/package_models.py)
deployment/dist/

# Local databases / caches
*.sqlite
*.sqlite3
*.db

# Misc tooling caches
wandb/
mlruns/
